{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2021",
    "lib": ["es2021"],
    "moduleResolution": "node16",
    "ignoreDeprecations": "5.0",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "nodes/**/*",
    "credentials/**/*",
    "index.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
