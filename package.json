{
  "name": "n8n-nodes-discord-bots",
  "version": "1.0.13",
  "description": "n8n community node package for building Discord bots with messages, reactions, slash commands, and interactions",
  "license": "MIT",
  "homepage": "https://github.com/SubParLou/n8n-nodes-discord-bots",
  "author": "Lou",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "discord",
    "bot",
    "slash-commands",
    "reactions"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SubParLou/n8n-nodes-discord-bots.git"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials package.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "main": "index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22 <23"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DiscordBotApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DiscordBot/DiscordBot.node.js",
      "dist/nodes/DiscordBot/DiscordBotTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "discord.js": "^14.26.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "gulp": "^5.0.0",
    "n8n-workflow": "2.17.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "uuid": "14.0.0"
  }
}
